{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Read(//root/.claude/**)",
      "Bash(pip install:*)",
      "Bash(python -m pytest:*)",
      "Bash(nvidia-smi)",
      "Bash(docker run:*)",
      "Bash(python3:*)",
      "WebFetch(domain:github.com)",
      "Bash(pnpm:*)",
      "Bash(curl:*)",
      "Bash(jobs -l)",
      "Bash(pkill:*)",
      "Bash(sed:*)",
      "Bash(docker exec:*)",
      "Bash(tmux list-panes *)",
      "Bash(awk '{print $2, $11, $12, $13, $14}')",
      "Bash(cp /mnt/e/Laboratory/vllm-from-scratch/.claude/teams/book-factory.json /root/.claude/teams/book-factory/config.json)",
      "Bash(rm -f /root/.claude/teams/book-factory/inboxes/*.json /root/.claude/teams/book-factory/.highwatermark)",
      "Bash(rm -f /root/.claude/tasks/book-factory/*.json)"
    ]
  },
  "hooks": {
    "TeammateIdle": [
      {
        "matcher": "book-factory",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[book-factory] Teammate idle — run TaskList to check available tasks'",
            "async": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /mnt/e/Laboratory/vllm-from-scratch/scripts/hook_pipeline.py",
            "async": true
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
