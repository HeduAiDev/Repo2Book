{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "WebSearch",
      "Read(//root/.claude/**)",
      "Bash(pip install:*)",
      "Bash(python -m pytest:*)",
      "Bash(nvidia-smi)",
      "Bash(docker run:*)",
      "Bash(python3:*)",
      "WebFetch(domain:github.com)",
      "Bash(pnpm:*)",
      "Bash(curl:*)",
      "Bash(jobs -l)",
      "Bash(pkill:*)",
      "Bash(sed:*)",
      "Bash(docker exec:*)",
      "Bash(tmux list-panes *)",
      "Bash(awk '{print $2, $11, $12, $13, $14}')",
      "Bash(cp /mnt/e/Laboratory/vllm-from-scratch/.claude/teams/book-factory.json /root/.claude/teams/book-factory/config.json)",
      "Bash(rm -f /root/.claude/teams/book-factory/inboxes/*.json /root/.claude/teams/book-factory/.highwatermark)",
      "Bash(rm -f /root/.claude/tasks/book-factory/*.json)",
      "Bash(git push *)",
      "Bash(git *)",
      "Bash(bash *)",
      "Bash(export:*)",
      "Bash(source:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(sleep:*)",
      "Bash(while:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(rm:*)",
      "Read(**)",
      "Bash(wsl.exe --version)",
      "Read(//proc/**)",
      "Read(//mnt/wsl/**)",
      "Bash(ip addr *)"
    ]
  },
  "hooks": {
    "TeammateIdle": [
      {
        "matcher": "book-factory",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/zjq/Repo2Book/scripts/hook_idle.py",
            "async": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /home/zjq/Repo2Book/scripts/hook_pipeline.py",
            "async": true
          }
        ]
      }
    ]
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true
}
