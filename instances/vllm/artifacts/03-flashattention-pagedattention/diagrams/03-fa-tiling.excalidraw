      "id": "note_text_2",
      "type": "text",
      "x": 80, "y": 385,
      "width": 700, "height": 24,
      "text": "KV tiles are re-read L/BLOCK = 3 times — cost of avoiding O(L²) HBM writes.",
      "originalText": "KV tiles are re-read L/BLOCK = 3 times — cost of avoiding O(L²) HBM writes.",
