{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Chapter Context",
  "description": "Persistent artifact for a single chapter — serves as the 'type signature' for cross-chapter consistency checking",

  "type": "object",
  "required": ["chapter_id", "version", "status", "dependencies", "dependents", "summary", "gates", "changelog"],
  "properties": {
    "chapter_id": {
      "type": "string",
      "description": "e.g. '03-kv-cache'"
    },
    "chapter_number": {
      "type": "integer"
    },
    "title": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "description": "Incremented on every modification"
    },
    "status": {
      "type": "string",
      "enum": ["draft", "implemented", "tested", "written", "reviewed", "published", "needs_fix"]
    },

    "dependencies": {
      "type": "array",
      "items": {"type": "string"},
      "description": "chapter_ids this chapter depends on"
    },
    "dependents": {
      "type": "array",
      "items": {"type": "string"},
      "description": "chapter_ids that depend on this chapter"
    },

    "summary": {
      "type": "object",
      "description": "Concise summary for cross-chapter consistency checking",
      "properties": {
        "key_concepts": {
          "type": "array",
          "items": {"type": "string"},
          "description": "2-5 key concepts introduced in this chapter"
        },
        "code_interface": {
          "type": "string",
          "description": "The public API surface of the code implemented in this chapter"
        },
        "prerequisites_assumed": {
          "type": "array",
          "items": {"type": "string"},
          "description": "What the reader is assumed to know before this chapter"
        },
        "narrative_tone": {
          "type": "string",
          "description": "The narrative approach used (e.g. 'from pain point first', 'theory then code')"
        },
        "running_example_stage": {
          "type": "string",
          "description": "How the running example evolves in this chapter"
        }
      },
      "required": ["key_concepts", "code_interface", "prerequisites_assumed"]
    },

    "gates": {
      "type": "object",
      "description": "Ralph-style backpressure gates",
      "properties": {
        "implementation_exists": {"type": "boolean", "default": false},
        "tests_pass": {"type": "boolean", "default": false},
        "narrative_complete": {"type": "boolean", "default": false},
        "review_approved": {"type": "boolean", "default": false},
        "downstream_consistency": {
          "type": "string",
          "enum": ["ok", "needs_check", "blocked"],
          "default": "needs_check"
        }
      }
    },

    "artifacts": {
      "type": "object",
      "description": "Paths to the actual artifacts produced by each agent",
      "properties": {
        "implementation_dir": {"type": "string"},
        "test_dir": {"type": "string"},
        "narrative_path": {"type": "string"},
        "review_path": {"type": "string"}
      }
    },

    "changelog": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "version": {"type": "integer"},
          "date": {"type": "string", "format": "date"},
          "event": {"type": "string"},
          "triggered_by": {"type": "string", "description": "user feedback or automated check that triggered this change"}
        }
      }
    }
  }
}
