{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Book Outline",
  "description": "The master outline for the vLLM from-scratch book",

  "type": "object",
  "required": ["title", "chapters", "running_example"],
  "properties": {
    "title": {"type": "string"},
    "reader_profile": {
      "type": "object",
      "properties": {
        "assumed_knowledge": {"type": "array", "items": {"type": "string"}},
        "target_level": {"type": "string", "enum": ["beginner", "intermediate", "advanced"]},
        "language": {"type": "string", "default": "zh-CN + en"}
      }
    },
    "running_example": {
      "type": "object",
      "properties": {
        "name": {"type": "string"},
        "description": {"type": "string"},
        "evolution": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "chapter_id": {"type": "string"},
              "role_in_chapter": {"type": "string"}
            }
          }
        }
      }
    },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "number", "title", "level"],
        "properties": {
          "id": {"type": "string"},
          "number": {"type": "integer"},
          "title": {"type": "string"},
          "level": {
            "type": "string",
            "enum": ["foundation", "core", "enhancement", "advanced"],
            "description": "Cognitive level (0-3 mapping)"
          },
          "covers": {"type": "string", "description": "What this chapter teaches"},
          "dependencies": {"type": "array", "items": {"type": "string"}},
          "status": {
            "type": "string",
            "enum": ["planned", "in_progress", "written", "reviewed", "published"]
          },
          "has_theory": {"type": "boolean"},
          "estimated_difficulty": {"type": "string", "enum": ["beginner", "intermediate", "advanced"]}
        }
      }
    }
  }
}
