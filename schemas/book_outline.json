{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Book Outline (v2, source-reading)",
  "description": "repo2book v2 大纲 schema —— 源码解读型。每本书 instances/<name>/book/cartography/outline-final.json 遵从此结构。由 cartography playbook（ARCHITECT-RUNBOOK §0.6）产出。",
  "type": "object",
  "required": ["book", "parts", "chapters"],
  "properties": {
    "book": {
      "type": "object",
      "required": ["title", "instance"],
      "properties": {
        "title": {"type": "string"},
        "instance": {"type": "string"},
        "kind": {"type": "string", "const": "source-reading"},
        "spine": {"type": "string", "description": "全书脊柱一句话（如：沿基座执行主线看衍生仓如何顶替每一站）"},
        "depends_on": {
          "type": "object",
          "description": "姊妹篇/衍生仓所依赖的基座实例（可选）",
          "properties": {
            "instance": {"type": "string"},
            "version": {"type": "string"},
            "source_dir": {"type": "string"},
            "sister_book": {"type": "string"}
          }
        },
        "reader_profile": {
          "type": "object",
          "properties": {
            "assumed_knowledge": {"type": "array", "items": {"type": "string"}},
            "target_level": {"type": "string", "enum": ["beginner", "intermediate", "advanced"]},
            "language": {"type": "string"}
          }
        }
      }
    },
    "parts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "intent": {"type": "string"}
        }
      }
    },
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["chapter_id", "slug", "title", "focus", "key_source_paths"],
        "properties": {
          "chapter_id": {"type": "string", "pattern": "^ch[0-9]{2}$"},
          "slug": {"type": "string", "pattern": "^ch[0-9]{2}-[a-z0-9-]+$"},
          "title": {"type": "string"},
          "focus": {"type": "string"},
          "part": {"type": "string"},
          "subsystem": {"type": "string"},
          "key_source_paths": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string"},
            "description": "本章主线源码（规范路径，相对 source/）；必须真实存在。"
          },
          "pairs_with": {
            "type": "object",
            "description": "姊妹篇配对：本章对位的基座书章号 + 基座源码路径（可选）",
            "properties": {
              "vllm_chapters": {"type": "array", "items": {"type": "string"}},
              "vllm_paths": {"type": "array", "items": {"type": "string"}}
            }
          },
          "deps": {"type": "array", "items": {"type": "string"}},
          "est_size": {"type": "string", "enum": ["S", "M", "L"]},
          "mode": {"type": "string", "enum": ["code", "meta"], "description": "code=完整流水线(有精简版)；meta=概览章(skip_impl)"},
          "flagship": {"type": "boolean"}
        }
      }
    },
    "pairing_map": {
      "type": "object",
      "description": "可选：本书章 ↔ 基座书章 的全量对照表 + 说明"
    }
  }
}
