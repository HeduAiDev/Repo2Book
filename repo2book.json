{
  "version": "1.0",
  "description": "repo2book — Turn any code repository into a source-grounded technical book via multi-agent pipeline.",
  "source": {
    "repo_url": "https://github.com/vllm-project/vllm.git",
    "repo_name": "vLLM",
    "source_dir": "instances/vllm/source",
    "language": "Python",
    "gpu_language": "CUDA → Triton",
    "submodule": true,
    "tracked_commit": "f3fef123504db07b3ac83ad4ef677915b53e8386"
  },
  "book": {
    "title": "vLLM 从零到专家：算子级深度解析",
    "reader_profile": {
      "assumed_knowledge": [
        "Python 高级编程",
        "PyTorch 深入使用",
        "CUDA/Triton 编程基础",
        "HPC 基础概念（带宽、延迟、并行模式）",
        "Transformer 架构深入理解"
      ],
      "target_level": "advanced",
      "language": "zh-CN",
      "style": "大白话 + 技术深度"
    },
    "outline_file": "instances/vllm/book/book-outline.json",
    "artifacts_dir": "instances/vllm/artifacts",
    "chapter_template": {
      "skeleton": [
        "implementation/__init__.py",
        "implementation/{module}.py",
        "tests/test_{module}.py",
        "narrative/chapter.md",
        "reviews/review-report.json"
      ]
    }
  },
  "pipeline": {
    "stages": [
      "implementer",
      "tester",
      "writer",
      "reviewer",
      "archivist"
    ],
    "gates": {
      "implementer": {
        "gate": "implementation_exists",
        "check": "File exists: artifacts/{chapter_id}/implementation/{module}.py"
      },
      "tester": {
        "gate": "tests_pass",
        "check": "python3 -m pytest artifacts/{chapter_id}/tests/ -q && echo PASS",
        "backpressure": true
      },
      "writer": {
        "gate": "narrative_complete",
        "check": "File exists: artifacts/{chapter_id}/narrative/chapter.md"
      },
      "reviewer": {
        "gate": "review_approved",
        "check": "jq -r '.verdict' artifacts/{chapter_id}/reviews/review-report.json | grep -q APPROVED",
        "backpressure": true,
        "auto_reject_triggers": [
          "\\text{} in formulas",
          "Missing code walkthrough",
          "Missing mathematical proof for non-trivial algorithms",
          "Cell 2-7 has 0 vLLM/file references for 3+ paragraphs",
          "Duplicate section/chapter IDs"
        ]
      },
      "archivist": {
        "gate": "delivery_recorded",
        "check": "File exists: artifacts/{chapter_id}/trace/delivery.md",
        "description": "Backup all agent session transcripts, create delivery record, update state.json, write session summary. This is the terminal stage — after this the chapter is PUBLISHED."
      }
    },
    "handoff": {
      "mechanism": "hook",
      "script": "scripts/hook_pipeline.py",
      "trigger": "PostToolUse → TaskUpdate",
      "pattern": "Agent completes task → hook writes handoff to next agent's inbox"
    },
    "lateral_communication": {
      "reviewer→writer": "REVISE instructions, bypassing Lead",
      "writer→implementer": "Change requests, bypassing Lead",
      "loop_detection": ">3 rounds on same issue → escalate to Lead"
    },
    "topology": {
      "default_mode": "linear",
      "modes": {
        "linear": {
          "description": "Default. A→B→C→D. 1 agent per stage. Efficient for standard chapters.",
          "agents_per_stage": {
            "implementer": 1,
            "tester": 1,
            "writer": 1,
            "reviewer": 1,
            "archivist": 1
          },
          "coordination": "handoff",
          "use_when": "Standard chapters with well-understood concepts"
        },
        "pair": {
          "description": "2 agents on a specified stage. Cross-check each other in real-time.",
          "agents_per_stage": {
            "implementer": 2,
            "tester": 1,
            "writer": 1,
            "reviewer": 1,
            "archivist": 1
          },
          "coordination": "pair_programming",
          "pair_roles": [
            "author",
            "reviewer"
          ],
          "pair_protocol": "One writes, one reviews. Switch halfway. Both must agree before handoff.",
          "use_when": "Complex algorithm implementation, unfamiliar code patterns, first-of-part chapter"
        },
        "panel": {
          "description": "2+ reviewers produce independent reports, then vote on verdict.",
          "agents_per_stage": {
            "implementer": 1,
            "tester": 1,
            "writer": 1,
            "reviewer": 2,
            "archivist": 1
          },
          "coordination": "voting",
          "panel_size": 2,
          "voting_protocol": "Each reviewer produces independent report. If both APPROVE → pass. If both REVISE → fail. If split → Lead decides.",
          "use_when": "First-of-part chapters (sets pattern for all subsequent), controversial design decisions"
        },
        "writer_editor": {
          "description": "Writer writes, editor reviews for style/readability before formal review.",
          "agents_per_stage": {
            "implementer": 1,
            "tester": 1,
            "writer": 2,
            "reviewer": 1,
            "archivist": 1
          },
          "coordination": "sequential_pair",
          "writer_roles": [
            "writer",
            "editor"
          ],
          "editor_focus": [
            "formula_renderability",
            "readability",
            "engagement",
            "coherence"
          ],
          "use_when": "Style-critical chapters (hook/intro chapters), chapters with many formulas"
        },
        "swarm": {
          "description": "All agents work simultaneously on different aspects. Merge at the end.",
          "agents_per_stage": {
            "implementer": 2,
            "tester": 1,
            "writer": 2,
            "reviewer": 2,
            "archivist": 1
          },
          "coordination": "discussion",
          "merge_protocol": "Each role produces independent output → book-editor merges → panel review → vote",
          "use_when": "Very complex chapter, brand new concept, sets patterns for entire Part"
        }
      },
      "decision_protocol": {
        "voting": {
          "quorum": ">50% of assigned agents must participate",
          "thresholds": {
            "majority": ">50% — standard decisions (REVISE vs APPROVE)",
            "supermajority": ">66% — structural decisions (chapter redesign, topology change)",
            "consensus": "100% — fundamental decisions (book outline changes, prompt rewrites)"
          },
          "tie_break": "Lead decides with written rationale"
        },
        "discussion": {
          "rounds_max": 3,
          "format": "proposal → argument_round → synthesis → vote_or_escalate",
          "escalation": "Any agent can escalate to Lead after 2 rounds without progress"
        },
        "escalation": {
          "triggers": [
            ">3 review cycles on same issue",
            "Pair agents disagree after pair_protocol",
            "Panel split vote (1 APPROVE, 1 REVISE)",
            "Pipeline stalled > 24h with no progress"
          ],
          "handler": "book-editor (Lead)",
          "resolution": "Lead decides or restructures (change topology, reassign agents, rewrite prompts)"
        }
      }
    }
  },
  "team": {
    "name": "book-factory",
    "config": "~/.claude/teams/book-factory/config.json",
    "agents": {
      "implementer": {
        "prompt_file": ".claude/agents/implementer.md",
        "model": "inherit",
        "backendType": "in-process",
        "color": "blue"
      },
      "tester": {
        "prompt_file": ".claude/agents/tester.md",
        "model": "inherit",
        "backendType": "in-process",
        "color": "yellow"
      },
      "writer": {
        "prompt_file": ".claude/agents/writer.md",
        "model": "inherit",
        "backendType": "tmux",
        "color": "green"
      },
      "reviewer": {
        "prompt_file": ".claude/agents/reviewer.md",
        "model": "inherit",
        "backendType": "tmux",
        "color": "red"
      },
      "archivist": {
        "prompt_file": ".claude/agents/archivist.md",
        "model": "inherit",
        "backendType": "in-process",
        "color": "cyan",
        "note": "Persistent role — not a pipeline stage. Records all events, backs up sessions, tracks outline changes, serves rehydration briefs."
      }
    }
  },
  "quality": {
    "linters": {
      "formula": "scripts/lint_formulas.py",
      "source_grounding": "scripts/lint_source_grounding.py"
    },
    "formula_rules": {
      "blocking": [
        "\\text{} → use \\mathrm{}",
        "\\boxed{} → use markdown bold header",
        "\\tag*{} → annotation outside $$ block",
        "\\frac in inline $...$ → promote to block $$...$$",
        "$$ on same line as formula content"
      ],
      "warnings": [
        "3+ inline formulas in one paragraph",
        "Inline formula > 30 characters"
      ]
    },
    "source_grounding_rules": {
      "every_cell_2_7": "1+ vllm file:line reference",
      "every_function": "# REFERENCE: vllm/path/file.py:L123",
      "source_mapping_table": "5+ rows",
      "impl_notes": "3+ vLLM files listed"
    }
  },
  "narrative": {
    "structure": {
      "cells": {
        "2": {
          "name": "Hook",
          "formality": 1,
          "requires_source_ref": true
        },
        "3": {
          "name": "Problem Demo",
          "formality": 2,
          "requires_source_ref": true
        },
        "4": {
          "name": "Theory",
          "formality": 5,
          "requires_source_ref": true
        },
        "5": {
          "name": "Walkthrough",
          "formality": 3,
          "requires_source_ref": true
        },
        "6": {
          "name": "Implementation",
          "formality": 3,
          "requires_source_ref": true
        },
        "7": {
          "name": "Numerical Example",
          "formality": 2,
          "requires_source_ref": true
        },
        "9": {
          "name": "Source Mapping",
          "formality": 4,
          "requires_source_ref": false
        },
        "10": {
          "name": "Verification",
          "formality": 3,
          "requires_source_ref": false
        },
        "11": {
          "name": "Summary",
          "formality": 1,
          "requires_source_ref": false
        }
      }
    },
    "rhythm": [
      "Source Trail (vllm file:line)",
      "Bridge (what/why)",
      "Theory Deep Dive (derivation + proof)",
      "Implementation (code)",
      "Source Diff (what vLLM adds beyond our version)"
    ],
    "algorithm_explanation": {
      "required_elements": [
        "Tiling visualization (svg-diagram skill)",
        "Step-by-step numerical trace (2+ iterations)",
        "Mathematical proof (induction for non-trivial algorithms)",
        "Memory/compute quantification (systems chapters)"
      ],
      "proof_requirements": {
        "must_have": "Inductive hypothesis + base case + inductive step + conclusion",
        "must_ground": "Numerical trace that maps symbols to concrete values",
        "must_scaffold": "Intuition before symbols, plain-language after every equation"
      }
    }
  },
  "memory_system": {
    "wisdom": {
      "description": "Universal patterns applicable to ANY repo2book project",
      "location": "wisdom/",
      "shared_across": "all instances",
      "gating": "Must appear in 2+ instances before promotion"
    },
    "trace": {
      "description": "Complete project memory — prevents context loss",
      "location": "instances/{instance}/trace/",
      "per_instance": true,
      "structure": {
        "INDEX.md": "Master index of all trace entries",
        "decisions/": "Design decisions, trade-offs, rationale",
        "deliveries/": "Per-chapter delivery records with context snapshots",
        "user_interactions/": "User feedback, Q&A requests, preferences",
        "context_summaries/": "Session summaries for agent context rehydration",
        "state.json": "Single source of truth for current project status"
      }
    },
    "archivist": {
      "description": "Dedicated agent maintaining project long-term memory",
      "per_instance": true,
      "agent_file": ".claude/agents/archivist.md",
      "tool": "scripts/archivist.py",
      "duties": [
        "Record every significant event in trace/",
        "Generate rehydration briefs for agents starting work",
        "Create session summaries after each session",
        "Answer queries about past decisions/deliveries/feedback",
        "Monitor context loss risk (turns > 50, session > 24h)",
        "Cross-reference related entries (bug→fix→test→chapter)"
      ]
    }
  },
  "instances": {
    "current": {
      "name": "vllm-from-scratch",
      "config": "instances/vllm/repo2book.json",
      "source_dir": "instances/vllm/source",
      "outline_file": "instances/vllm/book/book-outline.json",
      "artifacts_dir": "instances/vllm/artifacts",
      "knowledge_dir": "instances/vllm/knowledge",
      "trace_dir": "instances/vllm/trace"
    },
    "creating_new": {
      "steps": [
        "1. Clone this repo (repo2book) as template",
        "2. Clone the target repo into {source_dir}/",
        "3. Write book/book-outline.json for the target repo",
        "4. Update this file's 'source' section with repo URL, name, language",
        "5. Update CLAUDE.md with project-specific instructions",
        "6. Create the team: python3 scripts/team_orchestrator.py create-team",
        "7. Start a chapter: python3 scripts/team_orchestrator.py pipeline {chapter_id}"
      ]
    }
  }
}